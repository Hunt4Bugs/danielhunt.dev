---
import { NAV_LINKS } from '../data/site';
---
<header class="fixed top-0 inset-x-0 z-40 flex justify-center pt-5 px-6 pointer-events-none">
  <nav
    class="pointer-events-auto flex items-center gap-1 sm:gap-2 rounded-full px-2 py-2 sm:px-4 sm:py-2.5 backdrop-blur-xl"
    style="background: rgb(var(--surface) / 0.7); border: 1px solid rgb(var(--fore) / 0.08); box-shadow: 0 4px 24px rgb(var(--fore) / 0.06);"
    aria-label="Primary"
  >
    <a
      href="#top"
      class="px-3 sm:px-4 py-1.5 text-sm font-medium text-fore rounded-full transition-colors duration-300 hover:bg-fore/5"
      aria-label="Daniel Hunt — home"
    >
      DH
    </a>

    <span class="w-px h-4 bg-fore/10 mx-1 hidden sm:block" aria-hidden="true"></span>

    {NAV_LINKS.map((link) => (
      <a
        href={link.href}
        class="px-3 sm:px-4 py-1.5 text-[0.7rem] sm:text-xs text-sub font-light rounded-full transition-colors duration-300 hover:text-fore hover:bg-fore/5"
      >
        {link.label}
      </a>
    ))}
  </nav>

  <!-- Mobile menu button -->
  <button
    id="mobile-menu-btn"
    class="pointer-events-auto sm:hidden fixed top-5 right-6 flex items-center justify-center w-10 h-10 rounded-full backdrop-blur-xl text-fore"
    style="background: rgb(var(--surface) / 0.7); border: 1px solid rgb(var(--fore) / 0.08);"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <svg id="menu-icon-open" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16"/>
    </svg>
    <svg id="menu-icon-close" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" d="M6 6l12 12M6 18L18 6"/>
    </svg>
  </button>
</header>

<!-- Mobile drawer -->
<nav
  id="mobile-menu"
  class="sm:hidden fixed inset-0 z-30 hidden"
  aria-label="Mobile"
>
  <div class="absolute inset-0 bg-ground/95 backdrop-blur-xl"></div>
  <div class="relative flex flex-col items-center justify-center h-full gap-8">
    {NAV_LINKS.map((link) => (
      <a href={link.href} class="text-2xl font-medium text-fore hover:text-accent transition-colors duration-300">{link.label}</a>
    ))}
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('menu-icon-open')!;
  const iconClose = document.getElementById('menu-icon-close')!;

  btn.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden');
    const expanded = !open;
    btn.setAttribute('aria-expanded', String(expanded));
    btn.setAttribute('aria-label', expanded ? 'Close menu' : 'Open menu');
    iconOpen.classList.toggle('hidden', expanded);
    iconClose.classList.toggle('hidden', !expanded);
  });

  menu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', 'Open menu');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
