---
import { SITE } from '../data/site';

const techStack = [
  { name: 'Your existing tools', detail: 'Google Workspace, Microsoft 365' },
  { name: 'CRMs & helpdesks', detail: 'HubSpot, Pipedrive, Salesforce' },
  { name: 'Automation glue', detail: 'Zapier, Make, n8n' },
  { name: 'Custom builds', detail: 'Python, Next.js, Anthropic, OpenAI' },
];
---
<section id="about" class="section" aria-labelledby="about-heading">
  <div class="container-page">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 id="about-heading" class="display text-fore text-[clamp(2rem,5vw,3.5rem)] reveal">
        About <em>me</em>
      </h2>
    </div>

    <!-- Bento grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <!-- Bio card — spans 2 cols -->
      <div class="card sm:col-span-2 reveal reveal-delay-1">
        <p class="text-lg sm:text-xl leading-[1.7] text-sub">
          I'm a software engineer who works mostly with small businesses on
          the practical end of AI — the part where models meet real staff,
          messy data, and tools you already pay for. My job is to tell you
          <em class="text-fore not-italic font-medium">what</em> is worth doing, and then, if
          you want, to actually do it.
        </p>
        <p class="mt-6 text-lg sm:text-xl leading-[1.7] text-sub">
          I am independent, so I have no vendor to sell you and no hours to
          pad. The work should be boring in the good way: honest answers,
          sensible defaults, and something your team can still run on a
          Monday morning when I'm not around.
        </p>
      </div>

      <!-- Photo placeholder card -->
      <div class="card flex items-center justify-center aspect-square sm:aspect-auto reveal reveal-delay-2" style="background: rgb(var(--surface) / 0.8);">
        <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full flex items-center justify-center" style="background: rgb(var(--fore) / 0.05); border: 1px solid rgb(var(--fore) / 0.08);">
          <span class="font-serif text-4xl sm:text-5xl text-fore/10 select-none"><span class="text-fore/5">{'{'}</span>D<span class="text-fore/5">{'}'}</span></span>
        </div>
      </div>

      <!-- Tech stack card -->
      <div class="card reveal reveal-delay-2">
        <p class="text-[0.65rem] uppercase tracking-[0.25em] text-mute/60 mb-5">Tech stack</p>
        <div class="space-y-4">
          {techStack.map((tech) => (
            <div>
              <p class="font-medium text-fore">{tech.name}</p>
              <p class="text-sm text-sub">{tech.detail}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Approach card — spans 2 cols -->
      <div class="card sm:col-span-2 reveal reveal-delay-3">
        <p class="text-[0.65rem] uppercase tracking-[0.25em] text-mute/60 mb-5">Approach</p>
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="flex items-start gap-4">
            <span class="text-accent text-lg mt-0.5" aria-hidden="true">&#10003;</span>
            <div>
              <p class="font-medium text-fore">Audit before build</p>
              <p class="text-sm text-sub mt-1">Every engagement starts with understanding what you already have. Most small businesses need less new software than they think.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <span class="text-accent text-lg mt-0.5" aria-hidden="true">&#10003;</span>
            <div>
              <p class="font-medium text-fore">Boring tech, on purpose</p>
              <p class="text-sm text-sub mt-1">I plug AI into the tools you already use whenever I can, and only write custom code when an off-the-shelf option will not do the job.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
