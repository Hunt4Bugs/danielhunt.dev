---
import { SERVICES } from '../data/site';
---
<section id="services" class="section" aria-labelledby="services-heading">
  <div class="container-page">
    <h2
      id="services-heading"
      class="text-fore text-[clamp(2.25rem,5.5vw,4.5rem)] max-w-3xl reveal"
    >
      Four ways I tend to help.
    </h2>

    <ul class="mt-20 divide-y divide-fore/10 border-y border-fore/10 list-none p-0">
      {SERVICES.map((s, i) => (
        <li class={`group reveal reveal-delay-${Math.min(i + 1, 4)}`}>
          <article
            aria-labelledby={`svc-${s.slug}`}
            class="grid grid-cols-12 gap-6 items-start py-10 sm:py-14 transition-colors duration-700 hover:bg-surface -mx-6 px-6 sm:-mx-10 sm:px-10"
          >
            <span class="col-span-2 sm:col-span-1 text-[0.65rem] uppercase tracking-[0.2em] text-mute/50 mt-1.5" aria-hidden="true">
              {s.tag}
            </span>
            <h3
              id={`svc-${s.slug}`}
              class="col-span-10 sm:col-span-4 text-2xl sm:text-3xl font-medium text-fore transition-colors duration-500 group-hover:text-accent"
            >
              {s.title}
            </h3>
            <p class="col-span-12 sm:col-span-7 text-sub leading-relaxed text-base sm:text-lg max-w-xl">
              {s.blurb}
            </p>
          </article>
        </li>
      ))}
    </ul>
  </div>
</section>
