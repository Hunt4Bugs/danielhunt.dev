---
import { SERVICES } from '../data/site';
---
<section id="services" class="section" aria-labelledby="services-heading">
  <div class="container-page grid grid-cols-12 gap-6">
    <aside class="hidden md:flex md:col-span-2 flex-col gap-3">
      <span class="marker reveal">II</span>
    </aside>

    <div class="col-span-12 md:col-span-10">
      <span class="marker mb-4 reveal md:hidden">II</span>
      <h2
        id="services-heading"
        class="display text-fore text-[clamp(2.25rem,5.5vw,4.5rem)] max-w-3xl reveal"
      >
        Four ways I tend <em>to help.</em>
      </h2>

      <ul class="mt-20 divide-y divide-fore/10 border-y border-fore/10 list-none p-0">
        {SERVICES.map((s, i) => (
          <li class={`group reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <article
              aria-labelledby={`svc-${s.slug}`}
              class="grid grid-cols-12 gap-6 items-start py-10 sm:py-12 transition-colors duration-700 hover:bg-surface -mx-6 px-6 sm:-mx-10 sm:px-10"
            >
              <span class="col-span-2 sm:col-span-1 marker mt-1" aria-hidden="true">
                {s.tag}
              </span>
              <h3
                id={`svc-${s.slug}`}
                class="col-span-10 sm:col-span-4 font-serif text-2xl sm:text-3xl text-fore italic transition-colors duration-700 group-hover:text-accent"
              >
                {s.title}
              </h3>
              <p class="col-span-12 sm:col-span-7 text-sub leading-relaxed text-base sm:text-lg max-w-xl">
                {s.blurb}
              </p>
            </article>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
