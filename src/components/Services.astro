---
import { SERVICES } from '../data/site';
---
<section id="services" class="section" aria-labelledby="services-heading">
  <div class="container-page">
    <div class="max-w-3xl">
      <p class="mono-label reveal">Selected engagements</p>
      <h2
        id="services-heading"
        class="display mt-5 text-[clamp(2.5rem,7vw,5.5rem)] text-text reveal reveal-delay-1"
      >
        Four ways I tend to help.
      </h2>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-muted reveal reveal-delay-2">
        Consulting built around the unglamorous parts that decide whether an AI product survives contact with reality.
      </p>
    </div>

    <div class="mt-12 border-y border-line-strong">
      {SERVICES.map((s, i) => (
        <article
          aria-labelledby={`svc-${s.slug}`}
          class={`grid gap-6 border-b border-line px-0 py-8 last:border-b-0 md:grid-cols-[88px_minmax(0,1fr)_280px] reveal reveal-delay-${Math.min(i + 1, 4)}`}
        >
          <p class="mono-label">{s.tag}</p>
          <div>
            <h3
              id={`svc-${s.slug}`}
              class="text-[1.9rem] font-light tracking-[-0.04em] text-text"
            >
              {s.title}
            </h3>
            <p class="mt-3 max-w-3xl text-base leading-7 text-muted">
              {s.blurb}
            </p>
          </div>
          <div class="flex items-start md:justify-end">
            <a href="#contact" class="btn-quiet">
              Discuss this
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
