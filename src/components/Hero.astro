---
import { SITE } from '../data/site';
---
<section
  id="top"
  class="relative min-h-screen flex flex-col justify-center items-center text-center"
  aria-labelledby="hero-heading"
>
  <div class="container-page relative z-10 flex flex-col items-center">
    <p class="text-[0.6rem] uppercase tracking-[0.4em] text-accent/70 mb-10 reveal">AI Engineer &middot; Consultant</p>

    <h1
      id="hero-heading"
      class="display text-fore text-[clamp(3.5rem,10vw,9rem)] reveal reveal-delay-1"
    >
      Thoughtful AI<br/>
      systems, built<br/>
      to <em>last.</em>
    </h1>

    <p class="mt-14 max-w-xl text-lg sm:text-xl text-sub leading-relaxed reveal reveal-delay-2">
      I'm <strong class="font-medium text-fore">{SITE.name}</strong> —
      an independent AI engineer and consultant. I help companies design,
      ship, and operate AI products that age gracefully in production.
    </p>

    <div class="mt-14 flex flex-col sm:flex-row items-center gap-6 reveal reveal-delay-3">
      <a href="#contact" class="btn-ghost">Start a conversation</a>
      <a href="#services" class="link-cinema text-sub text-sm uppercase tracking-[0.2em]">
        See the work <span class="text-accent/40 ml-1" aria-hidden="true">&darr;</span>
      </a>
    </div>
  </div>

  <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-ground to-transparent pointer-events-none" aria-hidden="true"></div>
</section>
