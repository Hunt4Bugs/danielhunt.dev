---
import { SITE, SERVICES, FAQS } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = `${SITE.name} \u2014 ${SITE.jobTitle}`,
  description = SITE.description,
  ogImage = '/og.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE.url).toString();
const ogImageUrl = new URL(ogImage, SITE.url).toString();

// --- JSON-LD ----------------------------------------------------------------
const personSchema = {
  '@type': 'Person',
  '@id': `${SITE.url}/#person`,
  name: SITE.name,
  url: SITE.url,
  email: `mailto:${SITE.email}`,
  jobTitle: SITE.jobTitle,
  description: SITE.description,
  image: ogImageUrl,
  sameAs: [
    SITE.socials.linkedin,
    SITE.socials.x,
  ],
  knowsAbout: SITE.keywords,
};

const businessSchema = {
  '@type': 'ProfessionalService',
  '@id': `${SITE.url}/#business`,
  name: `${SITE.name} \u2014 AI Consulting`,
  url: SITE.url,
  email: `mailto:${SITE.email}`,
  founder: { '@id': `${SITE.url}/#person` },
  description: SITE.description,
  areaServed: 'Worldwide',
  serviceType: SERVICES.map((s) => s.title),
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'AI Services',
    itemListElement: SERVICES.map((s) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: s.title,
        description: s.blurb,
        provider: { '@id': `${SITE.url}/#person` },
      },
    })),
  },
};

const websiteSchema = {
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.description,
  publisher: { '@id': `${SITE.url}/#person` },
  inLanguage: 'en',
};

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: FAQS.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: SITE.url,
    },
  ],
};
---
<!-- Primary -->
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={SITE.name} />
<meta name="keywords" content={SITE.keywords.join(', ')} />
<link rel="canonical" href={canonical} />

<!-- Robots: explicit, generous -->
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_GB" />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- Theme -->
<meta name="theme-color" content="#F5F0EB" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#0A0A0A" media="(prefers-color-scheme: dark)" />
<meta name="color-scheme" content="light dark" />

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [personSchema, businessSchema, websiteSchema, faqSchema, breadcrumbSchema],
})} />
