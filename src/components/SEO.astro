---
import { SITE, SERVICES, FAQS } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = SITE.ogTitle,
  description = SITE.ogDescription ?? SITE.description,
  ogImage = '/og.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE.url).toString();
const ogImageUrl = new URL(ogImage, SITE.url).toString();
const xHandle = new URL(SITE.socials.x).pathname.replaceAll('/', '') || undefined;

// --- JSON-LD ----------------------------------------------------------------
const personSchema = {
  '@type': 'Person',
  '@id': `${SITE.url}/#person`,
  name: SITE.name,
  url: SITE.url,
  email: `mailto:${SITE.email}`,
  jobTitle: SITE.jobTitle,
  description: SITE.description,
  image: ogImageUrl,
  sameAs: [
    SITE.socials.linkedin,
    SITE.socials.x,
  ],
  knowsAbout: SITE.keywords,
};

const businessSchema = {
  '@type': 'ProfessionalService',
  '@id': `${SITE.url}/#business`,
  name: `${SITE.name} \u2014 AI & Data Engineering`,
  url: SITE.url,
  email: `mailto:${SITE.email}`,
  founder: { '@id': `${SITE.url}/#person` },
  description: SITE.description,
  areaServed: 'Worldwide',
  serviceType: SERVICES.map((s) => s.title),
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'AI & Data Engineering Services',
    itemListElement: SERVICES.map((s) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: s.title,
        description: s.blurb,
        provider: { '@id': `${SITE.url}/#person` },
      },
    })),
  },
};

const websiteSchema = {
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.description,
  publisher: { '@id': `${SITE.url}/#person` },
  inLanguage: 'en',
};

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: FAQS.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: SITE.url,
    },
  ],
};
---
<!-- Primary -->
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={SITE.name} />
<meta name="keywords" content={SITE.keywords.join(', ')} />
<link rel="canonical" href={canonical} />
<meta name="application-name" content={SITE.name} />
<meta name="apple-mobile-web-app-title" content={SITE.name} />

<!-- Robots: explicit, generous -->
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:secure_url" content={ogImageUrl} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${SITE.name} business-card preview — ${SITE.jobTitle}`} />
<meta property="og:locale" content="en_US" />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={`${SITE.name} business-card preview — ${SITE.jobTitle}`} />
{xHandle && <meta name="twitter:site" content={`@${xHandle}`} />}
{xHandle && <meta name="twitter:creator" content={`@${xHandle}`} />}

<!-- Theme -->
<meta name="theme-color" content="#FFFFFF" />
<meta name="msapplication-TileColor" content="#FFFFFF" />
<meta name="color-scheme" content="light" />

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [personSchema, businessSchema, websiteSchema, faqSchema, breadcrumbSchema],
})} />
