---
import { SITE } from '../data/site';

const year = new Date().getFullYear();
---
<footer class="border-t border-fore/5 mt-8" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Site footer</h2>
  <div class="container-page py-16 flex flex-col sm:flex-row items-center justify-between gap-8">
    <div class="text-center sm:text-left">
      <p class="text-sm font-medium text-fore">
        {SITE.name}
      </p>
      <p class="mt-1 text-[0.55rem] uppercase tracking-[0.3em] text-mute/50">
        &copy; {year} &middot; All rights reserved
      </p>
    </div>
    <ul class="flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm" aria-label="Social and contact links">
      <li>
        <a
          href={SITE.socials.linkedin}
          aria-label={`${SITE.name} on LinkedIn`}
          target="_blank"
          rel="noopener noreferrer me"
          class="link-cinema text-mute inline-flex items-center gap-2"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </li>
      <li>
        <a
          href={SITE.socials.x}
          aria-label={`${SITE.name} on X`}
          target="_blank"
          rel="noopener noreferrer me"
          class="link-cinema text-mute inline-flex items-center gap-2"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          X
        </a>
      </li>
      <li>
        <a href={`mailto:${SITE.email}`} class="link-cinema text-mute inline-flex items-center gap-2">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
          Email
        </a>
      </li>
    </ul>
  </div>
</footer>
