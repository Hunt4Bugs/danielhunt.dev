---
import { FAQS } from '../data/site';
---
<section id="faq" class="section" aria-labelledby="faq-heading">
  <div class="container-page">
    <div class="max-w-3xl">
      <p class="mono-label reveal">Questions</p>
      <h2 id="faq-heading" class="display mt-5 text-[clamp(2.4rem,6vw,4.75rem)] text-text reveal reveal-delay-1">
        Quick answers.
      </h2>
    </div>

    <div class="mt-10 border-y border-line-strong">
      {FAQS.map((f, i) => (
        <details class={`border-b border-line py-6 last:border-b-0 reveal reveal-delay-${Math.min(i + 1, 4)}`}>
          <summary class="grid cursor-pointer list-none gap-4 md:grid-cols-[220px_minmax(0,1fr)]">
            <span class="mono-label">Q{String(i + 1).padStart(2, '0')}</span>
            <span class="pr-8 text-[1.15rem] font-light tracking-[-0.02em] text-text">{f.q}</span>
          </summary>
          <div class="grid gap-4 pt-4 md:grid-cols-[220px_minmax(0,1fr)]">
            <span class="mono-label">Answer</span>
            <p class="max-w-4xl text-base leading-7 text-muted">{f.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
