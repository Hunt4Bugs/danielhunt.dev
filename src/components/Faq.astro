---
import { FAQS } from '../data/site';
---
<section id="faq" class="section" aria-labelledby="faq-heading">
  <div class="container-page max-w-4xl">
    <h2 id="faq-heading" class="text-fore text-[clamp(2.25rem,5vw,4rem)] reveal">
      Quick answers.
    </h2>

    <div class="mt-16 divide-y divide-fore/10 border-y border-fore/10">
      {FAQS.map((f, i) => (
        <details class={`group py-7 sm:py-8 cursor-pointer reveal reveal-delay-${Math.min(i + 1, 4)}`}>
          <summary class="flex items-start justify-between gap-6 list-none">
            <h3 class="text-lg sm:text-xl font-medium text-fore group-hover:text-accent group-open:text-accent transition-colors duration-500">
              {f.q}
            </h3>
            <span
              aria-hidden="true"
              class="text-mute/40 text-lg leading-none mt-0.5 transition-all duration-500 group-open:rotate-45 group-open:text-accent/60"
            >+</span>
          </summary>
          <p class="mt-5 text-sub leading-relaxed text-base sm:text-lg max-w-3xl">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
