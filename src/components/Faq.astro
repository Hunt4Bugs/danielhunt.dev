---
import { FAQS } from '../data/site';
---
<section id="faq" class="section" aria-labelledby="faq-heading">
  <div class="container-page max-w-3xl mx-auto">
    <div class="text-center mb-16">
      <h2 id="faq-heading" class="text-fore text-[clamp(2rem,5vw,3.5rem)] reveal">
        Quick answers
      </h2>
    </div>

    <div class="space-y-3">
      {FAQS.map((f, i) => (
        <details class={`group card cursor-pointer reveal reveal-delay-${Math.min(i + 1, 4)}`}>
          <summary class="flex items-start justify-between gap-6 list-none">
            <h3 class="text-base sm:text-lg font-medium text-fore group-hover:text-accent group-open:text-accent transition-colors duration-500">
              {f.q}
            </h3>
            <span
              aria-hidden="true"
              class="text-mute/40 text-lg leading-none mt-0.5 transition-all duration-500 group-open:rotate-45 group-open:text-accent/60 shrink-0"
            >+</span>
          </summary>
          <p class="mt-4 text-sub leading-relaxed text-[0.95rem]">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
