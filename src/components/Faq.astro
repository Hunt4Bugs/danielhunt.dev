---
import { FAQS } from '../data/site';
---
<section id="faq" class="section" aria-labelledby="faq-heading">
  <div class="container-page grid grid-cols-12 gap-6">
    <aside class="hidden md:flex md:col-span-2 flex-col gap-3">
      <span class="marker reveal">IV</span>
    </aside>

    <div class="col-span-12 md:col-span-10">
      <span class="marker mb-4 reveal md:hidden">IV</span>
      <h2 id="faq-heading" class="display text-fore text-[clamp(2.25rem,5vw,4rem)] reveal">
        Quick <em>answers.</em>
      </h2>

      <div class="mt-16 divide-y divide-fore/10 border-y border-fore/10">
        {FAQS.map((f, i) => (
          <details class={`group py-7 cursor-pointer reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <summary class="flex items-start justify-between gap-6 list-none">
              <h3 class="font-serif text-xl sm:text-2xl text-fore group-hover:text-accent group-open:text-accent transition-colors duration-500">
                {f.q}
              </h3>
              <span
                aria-hidden="true"
                class="text-mute/40 text-lg leading-none mt-1 transition-all duration-500 group-open:rotate-45 group-open:text-accent/60"
              >+</span>
            </summary>
            <p class="mt-5 text-sub leading-relaxed text-base sm:text-lg max-w-3xl">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>
