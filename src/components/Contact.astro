---
import { SITE } from '../data/site';

// TODO: replace YOUR_ACCESS_KEY with your Web3Forms access key
const WEB3FORMS_KEY = 'YOUR_ACCESS_KEY';
---
<section id="contact" class="section" aria-labelledby="contact-heading">
  <div class="container-page">
    <div class="grid md:grid-cols-2 gap-16 md:gap-20">
      <div>
        <h2 id="contact-heading" class="display text-fore text-[clamp(2.25rem,5.5vw,4.5rem)] reveal">
          Let's talk<br/>about <em>your project.</em>
        </h2>
        <p class="mt-8 text-lg text-sub leading-relaxed max-w-md reveal reveal-delay-1">
          Whether it's a quick audit, a months-long build, or a sanity check
          on an idea — drop a note. I reply within a couple of working days.
        </p>
        <a
          href={`mailto:${SITE.email}`}
          class="link-cinema mt-12 inline-flex items-center gap-3 text-xl sm:text-2xl font-medium text-fore reveal reveal-delay-2"
          aria-label={`Email ${SITE.name} at ${SITE.email}`}
        >
          {SITE.email}
          <span class="text-accent" aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <div>
        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="space-y-8 reveal reveal-delay-2"
          aria-label="Contact form"
        >
          <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
          <input type="hidden" name="subject" value="New enquiry from danielhunt.dev" />
          <input type="hidden" name="from_name" value="danielhunt.dev contact form" />
          <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <div>
            <label for="name" class="block text-[0.6rem] uppercase tracking-[0.3em] text-sub/50 mb-2">Name</label>
            <input id="name" name="name" type="text" autocomplete="name" required class="input-underline" />
          </div>
          <div>
            <label for="email" class="block text-[0.6rem] uppercase tracking-[0.3em] text-sub/50 mb-2">Email</label>
            <input id="email" name="email" type="email" autocomplete="email" required class="input-underline" />
          </div>
          <div>
            <label for="message" class="block text-[0.6rem] uppercase tracking-[0.3em] text-sub/50 mb-2">Message</label>
            <textarea id="message" name="message" rows="4" required class="input-underline resize-none"></textarea>
          </div>
          <div class="flex flex-col items-start gap-4 pt-2">
            <button type="submit" class="btn-ghost">Send message</button>
            <p class="text-[0.55rem] uppercase tracking-[0.2em] text-mute/50">
              Replies within 2 working days
            </p>
          </div>
        </form>

        <div class="mt-8 text-center md:hidden reveal reveal-delay-3">
          <p class="text-sm text-mute/60 mb-2">Or email directly</p>
          <a
            href={`mailto:${SITE.email}`}
            class="link-cinema text-lg font-medium text-fore"
          >
            {SITE.email} <span class="text-accent" aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
