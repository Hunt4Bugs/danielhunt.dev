---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../data/site';

const primaryColors = [
  { name: 'Ivory', token: 'ivory', hex: '#F5F0EB', usage: 'Background — the dominant surface', light: true },
  { name: 'Charcoal', token: 'charcoal', hex: '#1A1A1A', usage: 'Primary text, headings, logo' },
  { name: 'Wine', token: 'wine', hex: '#5C2E35', usage: 'Primary accent — CTAs, emphasis, interactive states' },
  { name: 'Wine Dark', token: 'wineDark', hex: '#452028', usage: 'Accent hover / pressed' },
];

const secondaryColors = [
  { name: 'Stone', token: 'stone', hex: '#E8E2DA', usage: 'Surface tint, cards, hover backgrounds', light: true },
  { name: 'Ash', token: 'ash', hex: '#6B6560', usage: 'Body copy, secondary text, icons' },
];

const accentColors = [
  { name: 'Olive', token: 'olive', hex: '#6B6A4E', usage: 'Tags, categories, subtle highlights' },
  { name: 'Sage', token: 'sage', hex: '#8C9583', usage: 'Status indicators, soft accents', light: true },
  { name: 'Teal', token: 'teal', hex: '#4A6F6D', usage: 'Links in content, differentiators' },
];

const typeScale = [
  { label: 'Display', class: 'display text-[clamp(2.5rem,6vw,5rem)]', sample: 'Thoughtful AI systems' },
  { label: 'Display Italic', class: 'display text-[clamp(2.5rem,6vw,5rem)] italic', sample: 'built to last.' },
  { label: 'Heading 2', class: 'font-serif text-[clamp(2rem,4vw,3.5rem)]', sample: 'Four ways I tend to help.' },
  { label: 'Heading 3', class: 'font-serif text-2xl sm:text-3xl italic', sample: 'AI Infrastructure' },
  { label: 'Body Large', class: 'font-sans text-lg sm:text-xl text-ash leading-relaxed', sample: 'I help companies design, ship, and operate AI products that age gracefully in production.' },
  { label: 'Body', class: 'font-sans text-base text-ash leading-relaxed', sample: 'Production-grade foundations: RAG, vector databases, model gateways, evals, observability and CI.' },
  { label: 'Caption', class: 'font-sans text-[0.65rem] uppercase tracking-[0.3em] text-ash/60', sample: 'AI Engineer · Consultant' },
];
---
<Layout title="Brand Guidelines — Daniel Hunt" description="Visual identity and brand guidelines for danielhunt.dev">
  <!-- Header -->
  <header class="container-page py-6 flex items-center justify-between">
    <a href="/" class="font-serif text-2xl tracking-tight text-charcoal" aria-label="Back to home">
      <span class="text-ash/40">{'{'}</span><span class="text-charcoal mx-[0.08em]">D</span><span class="text-ash/40">{'}'}</span>
    </a>
    <a href="/" class="link-cinema text-[0.65rem] uppercase tracking-[0.3em] text-ash/70 font-light">Back to site</a>
  </header>

  <main class="container-page pb-32">
    <!-- Title -->
    <section class="pt-16 sm:pt-28 pb-20 sm:pb-32 border-b border-charcoal/10">
      <p class="text-[0.65rem] uppercase tracking-[0.35em] text-ash/60 mb-8">Brand Guidelines</p>
      <h1 class="display text-charcoal text-[clamp(3rem,8vw,7rem)]">
        Visual<br/>Identity.
      </h1>
      <p class="mt-10 max-w-lg text-lg text-ash leading-relaxed">
        A reference for maintaining consistency across all touchpoints.
        Minimal by intent — every element earns its place.
      </p>
    </section>

    <!-- Logo -->
    <section class="py-20 sm:py-28 border-b border-charcoal/10">
      <div class="grid md:grid-cols-12 gap-12">
        <div class="md:col-span-4">
          <p class="text-[0.65rem] uppercase tracking-[0.3em] text-ash/60 mb-4">01</p>
          <h2 class="font-serif text-3xl text-charcoal">Logo</h2>
          <p class="mt-4 text-ash leading-relaxed">
            The monogram uses curly braces — a nod to code — framing the
            initial. Always rendered in the serif typeface. The braces are
            muted; the letter holds the weight.
          </p>
        </div>
        <div class="md:col-span-8">
          <div class="grid sm:grid-cols-2 gap-6">
            <!-- Light variant -->
            <div class="bg-ivory border border-charcoal/10 flex flex-col items-center justify-center py-16 px-8">
              <span class="font-serif text-6xl tracking-tight text-charcoal">
                <span class="text-ash/40">{'{'}</span><span class="mx-[0.12em]">D</span><span class="text-ash/40">{'}'}</span>
              </span>
              <p class="mt-6 text-[0.6rem] uppercase tracking-[0.25em] text-ash/50">On light</p>
            </div>
            <!-- Dark variant -->
            <div class="bg-charcoal flex flex-col items-center justify-center py-16 px-8">
              <span class="font-serif text-6xl tracking-tight text-ivory">
                <span class="text-ivory/30">{'{'}</span><span class="mx-[0.12em]">D</span><span class="text-ivory/30">{'}'}</span>
              </span>
              <p class="mt-6 text-[0.6rem] uppercase tracking-[0.25em] text-ivory/40">On dark</p>
            </div>
          </div>
          <!-- Clear space -->
          <div class="mt-6 border border-dashed border-charcoal/15 flex items-center justify-center py-12 px-8">
            <div class="relative">
              <span class="font-serif text-5xl tracking-tight text-charcoal">
                <span class="text-ash/40">{'{'}</span><span class="mx-[0.12em]">D</span><span class="text-ash/40">{'}'}</span>
              </span>
              <div class="absolute -inset-6 border border-dashed border-wine/30"></div>
            </div>
            <p class="ml-12 text-sm text-ash/60 max-w-xs">
              Maintain clear space equal to the height of the "D" on all sides. Never crowd the mark.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Colour Palette -->
    <section class="py-20 sm:py-28 border-b border-charcoal/10">
      <div class="grid md:grid-cols-12 gap-12">
        <div class="md:col-span-4">
          <p class="text-[0.65rem] uppercase tracking-[0.3em] text-ash/60 mb-4">02</p>
          <h2 class="font-serif text-3xl text-charcoal">Colour</h2>
          <p class="mt-4 text-ash leading-relaxed">
            Three tiers: primary colours carry the brand, secondary colours
            support readability, and accent colours add quiet range for
            categories, tags, and differentiation. Accent colours are never
            used for backgrounds or large surfaces.
          </p>
        </div>
        <div class="md:col-span-8 space-y-14">
          <!-- Primary -->
          <div>
            <p class="text-[0.6rem] uppercase tracking-[0.2em] text-ash/50 mb-5">Primary</p>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
              {primaryColors.map((c) => (
                <div>
                  <div
                    class={`aspect-[4/3] border border-charcoal/10 ${c.light ? '' : 'text-ivory'}`}
                    style={`background-color: ${c.hex};`}
                  >
                    <div class="p-3 h-full flex flex-col justify-end">
                      <p class={`text-[0.55rem] uppercase tracking-[0.2em] ${c.light ? 'text-charcoal/40' : 'text-ivory/50'}`}>
                        {c.hex}
                      </p>
                    </div>
                  </div>
                  <p class="mt-3 text-sm font-medium text-charcoal">{c.name}</p>
                  <p class="text-[0.6rem] text-ash/60 mt-0.5">{c.usage}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Secondary -->
          <div>
            <p class="text-[0.6rem] uppercase tracking-[0.2em] text-ash/50 mb-5">Secondary</p>
            <div class="grid grid-cols-2 gap-4">
              {secondaryColors.map((c) => (
                <div>
                  <div
                    class={`aspect-[5/2] border border-charcoal/10 ${c.light ? '' : 'text-ivory'}`}
                    style={`background-color: ${c.hex};`}
                  >
                    <div class="p-3 h-full flex flex-col justify-end">
                      <p class={`text-[0.55rem] uppercase tracking-[0.2em] ${c.light ? 'text-charcoal/40' : 'text-ivory/50'}`}>
                        {c.hex}
                      </p>
                    </div>
                  </div>
                  <p class="mt-3 text-sm font-medium text-charcoal">{c.name}</p>
                  <p class="text-[0.6rem] text-ash/60 mt-0.5">{c.usage}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Accent -->
          <div>
            <p class="text-[0.6rem] uppercase tracking-[0.2em] text-ash/50 mb-5">Accent</p>
            <div class="grid grid-cols-3 gap-4">
              {accentColors.map((c) => (
                <div>
                  <div
                    class={`aspect-[4/3] border border-charcoal/10 ${c.light ? '' : 'text-ivory'}`}
                    style={`background-color: ${c.hex};`}
                  >
                    <div class="p-3 h-full flex flex-col justify-end">
                      <p class={`text-[0.55rem] uppercase tracking-[0.2em] ${c.light ? 'text-charcoal/40' : 'text-ivory/50'}`}>
                        {c.hex}
                      </p>
                    </div>
                  </div>
                  <p class="mt-3 text-sm font-medium text-charcoal">{c.name}</p>
                  <p class="text-[0.6rem] text-ash/60 mt-0.5">{c.usage}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Ratio guidance -->
          <div>
            <div class="flex items-center gap-1 h-8">
              <div class="h-full bg-ivory border border-charcoal/10 flex-[45]"></div>
              <div class="h-full bg-charcoal flex-[25]"></div>
              <div class="h-full bg-ash flex-[12]"></div>
              <div class="h-full flex-[6]" style="background-color: #5C2E35;"></div>
              <div class="h-full flex-[4]" style="background-color: #6B6A4E;"></div>
              <div class="h-full flex-[4]" style="background-color: #8C9583;"></div>
              <div class="h-full flex-[4]" style="background-color: #4A6F6D;"></div>
            </div>
            <p class="mt-3 text-[0.6rem] uppercase tracking-[0.2em] text-ash/50">
              Approximate usage ratio — ivory dominates, accents whisper
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Typography -->
    <section class="py-20 sm:py-28 border-b border-charcoal/10">
      <div class="grid md:grid-cols-12 gap-12">
        <div class="md:col-span-4">
          <p class="text-[0.65rem] uppercase tracking-[0.3em] text-ash/60 mb-4">03</p>
          <h2 class="font-serif text-3xl text-charcoal">Typography</h2>
          <p class="mt-4 text-ash leading-relaxed">
            Two typefaces. EB Garamond for display and headings — a classic
            old-style serif with quiet authority. Inter for body copy and
            interface elements — clean, neutral, invisible.
          </p>
          <div class="mt-8 space-y-6">
            <div>
              <p class="text-[0.6rem] uppercase tracking-[0.2em] text-ash/50 mb-2">Display</p>
              <p class="font-serif text-2xl text-charcoal">EB Garamond</p>
              <p class="font-serif text-lg text-ash mt-1 italic">Regular &middot; Italic</p>
            </div>
            <div>
              <p class="text-[0.6rem] uppercase tracking-[0.2em] text-ash/50 mb-2">Body</p>
              <p class="font-sans text-lg text-charcoal">Inter</p>
              <p class="font-sans text-sm text-ash mt-1">Light &middot; Regular &middot; Medium</p>
            </div>
          </div>
        </div>
        <div class="md:col-span-8 space-y-10">
          {typeScale.map((t) => (
            <div class="border-b border-charcoal/5 pb-8">
              <p class="text-[0.6rem] uppercase tracking-[0.2em] text-ash/50 mb-4">{t.label}</p>
              <p class={`text-charcoal ${t.class}`}>{t.sample}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Spacing & Layout -->
    <section class="py-20 sm:py-28 border-b border-charcoal/10">
      <div class="grid md:grid-cols-12 gap-12">
        <div class="md:col-span-4">
          <p class="text-[0.65rem] uppercase tracking-[0.3em] text-ash/60 mb-4">04</p>
          <h2 class="font-serif text-3xl text-charcoal">Space</h2>
          <p class="mt-4 text-ash leading-relaxed">
            Generous negative space is a core brand value. Sections breathe.
            Content is constrained to a 72rem (1152px) max-width container
            with a 12-column grid.
          </p>
        </div>
        <div class="md:col-span-8">
          <div class="border border-charcoal/10 p-6">
            <div class="grid grid-cols-12 gap-2 h-48">
              {Array.from({ length: 12 }).map((_, i) => (
                <div class="bg-charcoal/5 flex items-end justify-center pb-2">
                  <span class="text-[0.55rem] text-ash/40">{i + 1}</span>
                </div>
              ))}
            </div>
            <div class="mt-4 grid grid-cols-12 gap-2">
              <div class="col-span-2 bg-wine/10 h-6 flex items-center justify-center">
                <span class="text-[0.5rem] text-wine/60">Rail</span>
              </div>
              <div class="col-span-10 bg-charcoal/5 h-6 flex items-center justify-center">
                <span class="text-[0.5rem] text-ash/50">Content</span>
              </div>
            </div>
          </div>
          <div class="mt-8 grid grid-cols-3 gap-6">
            <div>
              <p class="text-[0.6rem] uppercase tracking-[0.2em] text-ash/50 mb-2">Section gap</p>
              <p class="font-serif text-xl text-charcoal">8rem — 10rem</p>
              <p class="text-sm text-ash/60 mt-1">py-32 to py-40</p>
            </div>
            <div>
              <p class="text-[0.6rem] uppercase tracking-[0.2em] text-ash/50 mb-2">Container</p>
              <p class="font-serif text-xl text-charcoal">72rem</p>
              <p class="text-sm text-ash/60 mt-1">max-w-6xl</p>
            </div>
            <div>
              <p class="text-[0.6rem] uppercase tracking-[0.2em] text-ash/50 mb-2">Grid</p>
              <p class="font-serif text-xl text-charcoal">12 columns</p>
              <p class="text-sm text-ash/60 mt-1">2-col rail + 10-col body</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Voice & Tone -->
    <section class="py-20 sm:py-28 border-b border-charcoal/10">
      <div class="grid md:grid-cols-12 gap-12">
        <div class="md:col-span-4">
          <p class="text-[0.65rem] uppercase tracking-[0.3em] text-ash/60 mb-4">05</p>
          <h2 class="font-serif text-3xl text-charcoal">Voice</h2>
          <p class="mt-4 text-ash leading-relaxed">
            Direct, unhurried, precise. The writing matches the design —
            nothing superfluous, nothing loud. Confidence expressed
            through restraint.
          </p>
        </div>
        <div class="md:col-span-8">
          <div class="grid sm:grid-cols-2 gap-8">
            <div>
              <p class="text-[0.6rem] uppercase tracking-[0.2em] text-ash/50 mb-4">We are</p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <span class="text-wine mt-0.5 text-sm">&#10003;</span>
                  <span class="text-charcoal">Precise over vague</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-wine mt-0.5 text-sm">&#10003;</span>
                  <span class="text-charcoal">Candid over promotional</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-wine mt-0.5 text-sm">&#10003;</span>
                  <span class="text-charcoal">Calm over urgent</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-wine mt-0.5 text-sm">&#10003;</span>
                  <span class="text-charcoal">Considered over reactive</span>
                </li>
              </ul>
            </div>
            <div>
              <p class="text-[0.6rem] uppercase tracking-[0.2em] text-ash/50 mb-4">We avoid</p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <span class="text-ash/30 mt-0.5 text-sm">&times;</span>
                  <span class="text-ash">Buzzwords and hype</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-ash/30 mt-0.5 text-sm">&times;</span>
                  <span class="text-ash">Exclamation marks</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-ash/30 mt-0.5 text-sm">&times;</span>
                  <span class="text-ash">Superlatives without evidence</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-ash/30 mt-0.5 text-sm">&times;</span>
                  <span class="text-ash">Casual abbreviations</span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Components -->
    <section class="py-20 sm:py-28">
      <div class="grid md:grid-cols-12 gap-12">
        <div class="md:col-span-4">
          <p class="text-[0.65rem] uppercase tracking-[0.3em] text-ash/60 mb-4">06</p>
          <h2 class="font-serif text-3xl text-charcoal">Elements</h2>
          <p class="mt-4 text-ash leading-relaxed">
            Interactive components follow the same restraint — thin borders,
            subtle transitions, no filled backgrounds unless absolutely necessary.
          </p>
        </div>
        <div class="md:col-span-8 space-y-12">
          <!-- Buttons -->
          <div>
            <p class="text-[0.6rem] uppercase tracking-[0.2em] text-ash/50 mb-6">Buttons</p>
            <div class="flex flex-wrap items-center gap-6">
              <button class="btn-ghost">Ghost button</button>
              <a href="#" class="link-cinema font-serif text-xl text-charcoal">Text link <span class="text-wine">&rarr;</span></a>
            </div>
          </div>
          <!-- Dividers -->
          <div>
            <p class="text-[0.6rem] uppercase tracking-[0.2em] text-ash/50 mb-6">Dividers</p>
            <div class="space-y-6">
              <div>
                <div class="border-t border-charcoal/10"></div>
                <p class="mt-2 text-[0.55rem] text-ash/40 uppercase tracking-widest">Section — 10% opacity</p>
              </div>
              <div>
                <div class="border-t border-charcoal/20"></div>
                <p class="mt-2 text-[0.55rem] text-ash/40 uppercase tracking-widest">Emphasis — 20% opacity</p>
              </div>
            </div>
          </div>
          <!-- Roman numerals -->
          <div>
            <p class="text-[0.6rem] uppercase tracking-[0.2em] text-ash/50 mb-6">Section markers</p>
            <div class="flex items-center gap-12">
              {['I', 'II', 'III', 'IV', 'V'].map((n) => (
                <span class="marker">{n}</span>
              ))}
            </div>
            <p class="mt-4 text-sm text-ash/60">
              Roman numerals in the left rail orient the viewer. Quiet wayfinding.
            </p>
          </div>
          <!-- Grain texture -->
          <div>
            <p class="text-[0.6rem] uppercase tracking-[0.2em] text-ash/50 mb-6">Texture</p>
            <div class="relative border border-charcoal/10 h-32 bg-ivory overflow-hidden">
              <div class="grain" style="position: absolute; opacity: 0.08;"></div>
            </div>
            <p class="mt-4 text-sm text-ash/60">
              A barely perceptible film-grain overlay at 3% opacity. Adds warmth without decoration.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="border-t border-charcoal/10">
    <div class="container-page py-12 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-[0.6rem] uppercase tracking-[0.25em] text-ash/50">
        {SITE.name} &middot; Brand Guidelines &middot; {new Date().getFullYear()}
      </p>
      <a href="/" class="link-cinema text-[0.6rem] uppercase tracking-[0.25em] text-ash/50">Return to site</a>
    </div>
  </footer>
</Layout>
