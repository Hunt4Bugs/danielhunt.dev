---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../data/site';

const navLinks = ['Work', 'Journal', 'About', 'Contact'];
const journalEntries = [
  { number: '001', date: '2026 · 04', title: 'The quiet discipline of finishing things', meta: 'Essay · Process', readTime: '8 MIN' },
  { number: '002', date: '2026 · 03', title: 'A taxonomy of slow work', meta: 'Essay · Philosophy', readTime: '6 MIN' },
  { number: '003', date: '2026 · 02', title: 'Shipping a GxP-compliant scheduler in six weeks', meta: 'Case Study · Product', readTime: '12 MIN' },
  { number: '004', date: '2026 · 01', title: 'Six subagents and a relay', meta: 'Build Log · Infra', readTime: '4 MIN' },
  { number: '005', date: '2025 · 12', title: 'Notes on outcome-based positioning', meta: 'Note · Marketing', readTime: '3 MIN' },
];
---

<Layout title="Patterns — Daniel Hunt" description="Figma-aligned patterns and brand reference for danielhunt.dev">
  <main class="container-page pb-24 pt-12 sm:pt-16">
    <section class="border-b border-line-strong pb-16 sm:pb-24">
      <p class="mono-label">III — Patterns</p>
      <h1 class="display mt-5 text-[clamp(3.5rem,8vw,7rem)] text-text">Patterns</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-muted">
        Composed layouts for the site: navigation, landing spread, journal index, work detail, and the closing footer system.
      </p>
    </section>

    <section class="section border-b border-line-strong">
      <div class="mb-8">
        <p class="mono-label">A — Navigation</p>
        <h2 class="mt-3 text-[2rem] font-light tracking-[-0.04em] text-text">Navigation</h2>
      </div>

      <div class="space-y-8">
        <div>
          <p class="mono-label mb-4">Light</p>
          <div class="flex items-center justify-between border-y border-line-strong py-6">
            <div class="display monogram text-[1.75rem] text-text"><span class="monogram-brace">{'{'}</span>D<span class="monogram-brace">{'}'}</span></div>
            <div class="hidden items-center gap-10 text-sm text-muted md:flex">
              {navLinks.map((link) => <span>{link}</span>)}
            </div>
            <span class="mono-label">LA · 9:42 PM</span>
          </div>
        </div>

        <div>
          <p class="mono-label mb-4">Dark specimen</p>
          <div class="bg-text px-8 py-6 text-white">
            <div class="flex items-center justify-between">
              <div class="display monogram text-[1.75rem]"><span class="scale-[0.82] -translate-y-[0.02em] text-white/35">{'{'}</span>D<span class="scale-[0.82] -translate-y-[0.02em] text-white/35">{'}'}</span></div>
              <div class="hidden items-center gap-10 text-sm text-white/60 md:flex">
                {navLinks.map((link) => <span>{link}</span>)}
              </div>
              <span class="font-mono text-[0.625rem] uppercase tracking-[0.22em] text-white/50">LA · 9:42 PM</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section border-b border-line-strong">
      <div class="mb-8">
        <p class="mono-label">B — Hero</p>
        <h2 class="mt-3 text-[2rem] font-light tracking-[-0.04em] text-text">Landing spread</h2>
      </div>

      <div class="border border-line-strong">
        <div class="flex items-center justify-between border-b border-line px-8 py-5">
          <div class="display monogram text-[1.5rem] text-text"><span class="monogram-brace">{'{'}</span>D<span class="monogram-brace">{'}'}</span></div>
          <div class="hidden items-center gap-8 text-sm text-muted md:flex">
            <span>Work</span>
            <span>Journal</span>
            <span>About</span>
          </div>
        </div>
        <div class="px-8 py-16 sm:px-14 sm:py-24">
          <p class="mono-label">INDEX · 2024—2026</p>
          <h3 class="display-tight mt-8 text-[clamp(3rem,10vw,7.5rem)] text-text">Work. Thought.<br />What&apos;s shipped.</h3>
          <p class="mt-8 max-w-4xl text-[1.45rem] font-light leading-[1.45] tracking-[-0.03em] text-muted">
            An index of software, essays, and experiments from {SITE.name}.
          </p>
          <div class="mt-10 flex flex-wrap gap-3">
            <a class="btn-primary" href="/">View selected work</a>
            <a class="btn-quiet" href="/">Read journal</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section border-b border-line-strong">
      <div class="mb-8">
        <p class="mono-label">C — Journal</p>
        <h2 class="mt-3 text-[2rem] font-light tracking-[-0.04em] text-text">Journal index</h2>
      </div>

      <div class="border-y border-line-strong">
        <div class="flex flex-wrap items-center gap-4 border-b border-line py-6">
          <span class="mono-label">Filter</span>
          <span class="bg-text px-3 py-1.5 text-xs font-medium text-white">All</span>
          <span class="px-3 py-1.5 text-xs text-muted">Essays</span>
          <span class="px-3 py-1.5 text-xs text-muted">Case Studies</span>
          <span class="px-3 py-1.5 text-xs text-muted">Build Logs</span>
          <span class="px-3 py-1.5 text-xs text-muted">Notes</span>
          <span class="ml-auto mono-label">47 entries</span>
        </div>

        {journalEntries.map((entry) => (
          <article class="grid gap-4 border-b border-line py-7 last:border-b-0 md:grid-cols-[60px_120px_minmax(0,1fr)_80px] md:items-center md:gap-12">
            <p class="mono-label">{entry.number}</p>
            <p class="mono-label">{entry.date}</p>
            <div>
              <h3 class="text-[1.35rem] font-light tracking-[-0.03em] text-text">{entry.title}</h3>
              <p class="mt-1 text-sm text-quiet">{entry.meta}</p>
            </div>
            <p class="mono-label md:text-right">{entry.readTime}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section border-b border-line-strong">
      <div class="mb-8">
        <p class="mono-label">D — Case Study</p>
        <h2 class="mt-3 text-[2rem] font-light tracking-[-0.04em] text-text">Work detail template</h2>
      </div>

      <div class="border border-line-strong">
        <div class="flex flex-wrap items-center gap-3 border-b border-line px-8 py-5">
          <span class="mono-label">← Back</span>
          <span class="mono-label">•</span>
          <span class="mono-label">Work</span>
          <span class="mono-label">•</span>
          <span class="mono-label text-text">001 / Data Vial</span>
        </div>

        <div class="space-y-8 px-8 py-10 sm:px-14 sm:py-16">
          <div class="flex flex-wrap items-center gap-4">
            <span class="mono-label">001</span>
            <span class="mono-label">•</span>
            <span class="mono-label">Case study</span>
            <span class="mono-label">•</span>
            <span class="mono-label">2026 · ongoing</span>
          </div>
          <h3 class="display text-[clamp(3rem,7vw,5.8rem)] text-text">Data Vial</h3>
          <p class="max-w-5xl text-[1.5rem] font-light leading-[1.45] tracking-[-0.03em] text-muted">
            A GxP-compliant lab operations platform, designed around the work that actually happens in pharmaceutical quality labs.
          </p>
          <div class="grid gap-6 border-t border-line pt-8 md:grid-cols-4">
            <div>
              <p class="mono-label">Role</p>
              <p class="mt-3 text-sm text-text">Solo founder, design + eng</p>
            </div>
            <div>
              <p class="mono-label">Stack</p>
              <p class="mt-3 text-sm text-text">Next.js · FastAPI · Supabase</p>
            </div>
            <div>
              <p class="mono-label">Timeline</p>
              <p class="mt-3 text-sm text-text">2025 — ongoing</p>
            </div>
            <div>
              <p class="mono-label">Sector</p>
              <p class="mt-3 text-sm text-text">Pharmaceutical QC</p>
            </div>
          </div>
        </div>

        <div class="bg-panel px-8 py-8">
          <p class="mono-label">// HERO SHOT · 1400 × 800 · 7:4</p>
          <div class="mt-4 h-[22rem] sm:h-[34rem]"></div>
        </div>

        <div class="space-y-8 px-8 py-10 sm:px-14 sm:py-16">
          <div class="max-w-4xl">
            <p class="mono-label">Overview</p>
            <p class="mt-5 text-[1.9rem] font-light leading-[1.45] tracking-[-0.03em] text-text">
              The core product solves staff qualifications, demand planning, scheduling, and GxP compliance — replacing the manual spreadsheet and LIMS cross-referencing that most pharma labs still run on.
            </p>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <div class="bg-panel p-5">
              <p class="mono-label">// PRODUCT SHOT · 636 × 476</p>
              <div class="h-72 sm:h-[26rem]"></div>
            </div>
            <div class="bg-panel p-5">
              <p class="mono-label">// DETAIL SHOT · 636 × 476</p>
              <div class="h-72 sm:h-[26rem]"></div>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-between border-t border-line px-8 py-10">
          <div>
            <p class="mono-label">← Previous</p>
            <p class="mt-2 text-xl font-light tracking-[-0.03em] text-text">000 — Index</p>
          </div>
          <div class="text-right">
            <p class="mono-label">Next →</p>
            <p class="mt-2 text-xl font-light tracking-[-0.03em] text-text">002 — Roundz</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="mb-8">
        <p class="mono-label">E — Footer</p>
        <h2 class="mt-3 text-[2rem] font-light tracking-[-0.04em] text-text">The close</h2>
      </div>

      <div class="border-t border-line-strong pt-10">
        <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_180px_180px_180px]">
          <div>
            <div class="display monogram text-[2.4rem] text-text"><span class="monogram-brace">{'{'}</span>D<span class="monogram-brace">{'}'}</span></div>
            <p class="mt-6 max-w-xs text-[1.2rem] font-light leading-8 text-muted">
              {SITE.name}<br />
              {SITE.location}
            </p>
          </div>
          <div class="space-y-4">
            <p class="mono-label">Index</p>
            <p class="text-sm text-text">Work</p>
            <p class="text-sm text-text">Journal</p>
            <p class="text-sm text-text">About</p>
          </div>
          <div class="space-y-4">
            <p class="mono-label">Elsewhere</p>
            <p class="text-sm text-text">LinkedIn</p>
            <p class="text-sm text-text">X / Twitter</p>
            <p class="text-sm text-text">Brand</p>
          </div>
          <div class="space-y-4">
            <p class="mono-label">Correspond</p>
            <p class="text-sm text-text">Email</p>
            <p class="text-sm text-text">Inquiry form</p>
            <p class="text-sm text-text">RSS</p>
          </div>
        </div>

        <div class="mt-12 flex flex-col gap-3 border-t border-line py-6 md:flex-row md:items-center md:justify-between">
          <p class="mono-value">© MMXXVI · DANIEL HUNT · ALL RIGHTS RESERVED</p>
          <p class="mono-value">SET IN INTER · DESIGN SYSTEM V1</p>
        </div>
      </div>
    </section>
  </main>
</Layout>
